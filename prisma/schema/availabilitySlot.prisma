model AvailabilitySlot {
  id             String       @id @default(uuid())
  tutorProfileId String
  date           DateTime
  startTime      DateTime
  endTime        DateTime
  isBooked       Boolean      @default(false)
  tutorProfile   TutorProfile @relation("TutorAvailability", fields: [tutorProfileId], references: [id])
  bookings       Booking[]    @relation("SlotBookings")
}

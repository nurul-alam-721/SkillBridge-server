model TutorProfile {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id])

  bio        String
  hourlyRate Float
  experience Int

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  availability AvailabilitySlot[]
  bookings     Booking[]
  reviews      Review[]
}